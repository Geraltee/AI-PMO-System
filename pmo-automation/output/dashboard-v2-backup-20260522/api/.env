# ═══════════════════════════════════════════════
#  PMO Dashboard — AI 配置文件
# ═══════════════════════════════════════════════
#
#  使用方法：
#    1. 复制本文件为 .env
#    2. 填入你的 API Key
#    3. 运行 node server.js
#
#  获取 API Key：
#    https://open.bigmodel.cn → 控制台 → API Keys
#

# 智谱 AI API Key（必填）
# 格式：xxxxxxxxxxxxxxxx.xxxxxx
ZHIPU_API_KEY=c352cdd44f064d029627edb0d2a58796.fmW0lKasVtAr9oSv

# 服务端口（默认 3456）
PORT=3456

# 使用的模型名称
# 可选值：glm-4-plus / glm-4-flash / glm-4-long / glm-4v-plus（图片理解）
AI_MODEL=glm-4-plus
